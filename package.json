{
  "name": "newspost-auto-desktop",
  "version": "1.0.0",
  "description": "NewsPost Auto — NovasBeat Instagram Autopost Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-client": "cd client && npm run build",
    "pack": "npm run build-client && electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.novasbeat.autopost",
    "productName": "NewsPost Auto",
    "copyright": "NovasBeat",
    "asar": true,
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": ["**/*", "!**/node_modules/**"]
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "client/dist",
        "to": "client/dist"
      }
    ],
    "extraFiles": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        { "target": "dir", "arch": ["x64"] }
      ],
      "icon": "build-assets/icon.ico"
    },
    "directories": {
      "output": "dist-app",
      "buildResources": "build-assets"
    }
  }
}
